<Window x:Class="WpfTaskFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskFlow" Height="650" Width="900"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Конвертер bool -> Visibility для панелі дій -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль кнопок -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль текстових полів -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Стиль ComboBox -->
        <Style x:Key="PriorityCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Бічна панель -->
        <Border Grid.Column="0" Background="#181825" Padding="12">
            <StackPanel>
                <!-- Логотип -->
                <TextBlock Text="✓ TaskFlow"
                           Foreground="#CBA6F7"
                           FontSize="22"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Margin="0,10,0,30"/>

                <!-- Кнопки навігації — тепер через Command -->
                <Button Content="📋  Всі задачі"
                        Style="{StaticResource MenuButton}"
                        Command="{Binding ShowAllCommand}"/>
                <Button Content="🔥  Активні"
                        Style="{StaticResource MenuButton}"
                        Command="{Binding ShowActiveCommand}"/>
                <Button Content="✅  Виконані"
                        Style="{StaticResource MenuButton}"
                        Command="{Binding ShowCompletedCommand}"/>
                <Button Content="📊  Статистика"
                        Style="{StaticResource MenuButton}"
                        Command="{Binding ShowStatsCommand}"/>

                <Separator Background="#45475A" Margin="0,16,0,16"/>

                <Button Content="➕  Додати задачу"
                        Style="{StaticResource MenuButton}"
                        Background="#CBA6F7"
                        Foreground="#1E1E2E"
                        FontWeight="Bold"
                        Command="{Binding AddTaskCommand}"/>
            </StackPanel>
        </Border>

        <!-- Основна панель -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок — тепер через Binding -->
            <TextBlock Grid.Row="0"
                       Text="{Binding PageTitle}"
                       Foreground="#CDD6F4"
                       FontSize="24"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       Margin="0,0,0,16"/>

            <!-- Список задач — ItemsSource і SelectedItem через Binding -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Tasks}"
                      SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="#CDD6F4"
                      FontFamily="Segoe UI"
                      FontSize="14">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="#CDD6F4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemBorder"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4">
                                        <GridViewRowPresenter
                                            Columns="{TemplateBinding GridView.ColumnCollection}"
                                            Content="{TemplateBinding Content}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#313244"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder"
                                                    Property="Background"
                                                    Value="#45475A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="50"
                                        DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Назва" Width="200"
                                        DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Пріоритет" Width="100"
                                        DisplayMemberBinding="{Binding Priority}"/>
                        <GridViewColumn Header="Статус" Width="100"
                                        DisplayMemberBinding="{Binding StatusText}"/>
                        <GridViewColumn Header="Створено" Width="150"
                                        DisplayMemberBinding="{Binding CreatedAtText}"/>
                        <GridViewColumn Header="Опис" Width="200"
                                        DisplayMemberBinding="{Binding Description}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Панель дій — Visibility через BooleanToVisibilityConverter -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding IsTaskSelected, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,10">
                <Button Content="✅ Виконано"
                        Style="{StaticResource MenuButton}"
                        Background="#A6E3A1"
                        Foreground="#1E1E2E"
                        Width="120"
                        Margin="0,0,8,0"
                        Command="{Binding CompleteTaskCommand}"/>
                <Button Content="✏️ Редагувати"
                        Style="{StaticResource MenuButton}"
                        Background="#89B4FA"
                        Foreground="#1E1E2E"
                        Width="130"
                        Margin="0,0,8,0"
                        Command="{Binding EditTaskCommand}"/>
                <Button Content="🗑️ Видалити"
                        Style="{StaticResource MenuButton}"
                        Background="#F38BA8"
                        Foreground="#1E1E2E"
                        Width="120"
                        Command="{Binding DeleteTaskCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
