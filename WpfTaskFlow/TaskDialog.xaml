<Window x:Class="WpfTaskFlow.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="380" Width="380"
        Background="#1E1E2E"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="24">
        <TextBlock Text="Назва *"
                   Foreground="#CDD6F4"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Margin="0,0,0,6"/>
        <Border Background="#313244" CornerRadius="8" Padding="2">
            <TextBox x:Name="TitleBox"
                     Background="Transparent"
                     Foreground="#CDD6F4"
                     BorderThickness="0"
                     Padding="8,6"
                     FontSize="14"
                     FontFamily="Segoe UI"/>
        </Border>

        <TextBlock Text="Опис"
                   Foreground="#CDD6F4"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Margin="0,16,0,6"/>
        <Border Background="#313244" CornerRadius="8" Padding="2">
            <TextBox x:Name="DescBox"
                     Background="Transparent"
                     Foreground="#CDD6F4"
                     BorderThickness="0"
                     Padding="8,6"
                     FontSize="14"
                     FontFamily="Segoe UI"
                     Height="60"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </Border>

        <TextBlock Text="Пріоритет"
                   Foreground="#CDD6F4"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Margin="0,16,0,6"/>
        <ComboBox x:Name="PriorityBox"
                  Height="38"
                  FontSize="14"
                  FontFamily="Segoe UI">
            <ComboBoxItem Content="Low"/>
            <ComboBoxItem Content="Medium" IsSelected="True"/>
            <ComboBoxItem Content="High"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="Скасувати"
                    Width="100"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="#45475A"
                    Foreground="#CDD6F4"
                    BorderThickness="0"
                    FontFamily="Segoe UI"
                    Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Content="Зберегти"
                    Width="100"
                    Height="36"
                    Background="#CBA6F7"
                    Foreground="#1E1E2E"
                    BorderThickness="0"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>